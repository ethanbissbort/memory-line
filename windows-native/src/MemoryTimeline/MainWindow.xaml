<Window
    x:Class="MemoryTimeline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Memory Timeline">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.KeyboardAccelerators>
            <!-- Ctrl+R refreshes the current page in place (timeline refresh, not renavigation) -->
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="Refresh_Invoked"/>
        </Grid.KeyboardAccelerators>
        <NavigationView
            x:Name="NavigationView"
            IsBackButtonVisible="Auto"
            IsSettingsVisible="True"
            PaneDisplayMode="Top"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            SelectionChanged="NavigationView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Timeline" Tag="Timeline" Icon="Calendar"/>
                <NavigationViewItem Content="Queue" Tag="Queue" Icon="Microphone"/>
                <NavigationViewItem Content="Review" Tag="Review" Icon="Accept"/>
                <NavigationViewItem Content="Connections" Tag="Connections">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71B;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Eras" Tag="Eras">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Search" Tag="Search" Icon="Find"/>
                <NavigationViewItem Content="Analytics" Tag="Analytics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <!-- Pages will be navigated here -->
            </Frame>
        </NavigationView>
    </Grid>
</Window>
